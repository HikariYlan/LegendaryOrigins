{
  "name": "À dos de dragon",
  "description": "Tu es suffisamment fort pour porter quelqu'un sur tes épaules. N'importe qui peut monter sur toi pendant que tu es immobile, et tu peux ensuite t'envoler avec eux ! Accroupis-toi et saute pour le faire descendre.",
  "type": "apoli:multiple",
  "ride_mount": {
    "type": "apoli:action_on_being_used",
    "bientity_action": {
      "type": "apoli:and",
      "actions": [
        {
          "type": "apoli:mount"
        }
      ]
    },
    "condition": {
      "type": "apoli:and",
      "conditions": [
        {
          "type": "apoli:moving",
          "inverted": true
        },
        {
          "type": "apoli:sneaking"
        },
        {
          "type": "apoli:passenger",
          "inverted": true
        }
      ]
    }
  },
  "ride_dismount_self": {
    "type": "apoli:active_self",
    "cooldown": 1,
    "hud_render": {
      "should_render": false
    },
    "entity_action": {
      "type": "origins:if_else_list",
      "actions": [
        {
          "condition": {
            "type": "apoli:and",
            "conditions": [
              {
                "type": "apoli:sneaking"
              },
              {
                "type": "apoli:passenger"
              }
            ]
          },
          "action": {
            "type": "apoli:and",
            "actions": [
              {
                "type": "apoli:passenger_action",
                "action": {
                  "type": "apoli:dismount"
                }
              }
            ]
          }
        }
      ]
    },
    "key": {
      "key": "key.jump"
    }
  }
}